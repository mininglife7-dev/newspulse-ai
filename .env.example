# Firecrawl API key — get yours at https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key-here

# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ---------------------------------------------------------------------------
# Durable rate limiting (OPTIONAL but recommended for production).
# Without these, rate limiting uses a per-instance in-memory counter that
# resets on scale/restart — it cannot stop a distributed abuser from running
# up your paid Firecrawl/OpenAI spend. Configure a free Upstash Redis to make
# limits hold across all serverless instances. The mode in use is reported at
# GET /api/health (rate_limiting.durable).
# Create one at https://upstash.com → Redis → REST API.
# ---------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
