# EURO AI — AI Governance Platform
# Supabase configuration (create a project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Email Notifications (SendGrid) - Phase 4 enhancement
# Sign up at https://sendgrid.com - free tier available
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=notifications@yourapp.com
SENDGRID_FROM_NAME=EURO AI Compliance

# Cron job authentication - generate a secure random string for cron jobs
CRON_SECRET=your-secure-cron-secret-here

# Application URL - for email links
NEXT_PUBLIC_APP_URL=https://euro-ai.example.com

# Optional: for future AI features
# OPENAI_API_KEY=sk-your-openai-api-key-here
