# EURO AI — AI Governance Platform
# Supabase configuration (create a project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_PROJECT_ID=your-project-ref

# Deployment & CI/CD configuration
GITHUB_OWNER=your-github-owner
GITHUB_REPO=your-github-repo

# Monitoring & Health Check
NEXT_PUBLIC_APP_URL=https://your-production-url.vercel.app

# Admin & Monitoring Authentication
# REQUIRED for production: Secure token for monitoring endpoints (/api/alerts, /api/incident, etc.)
# and destructive endpoints (DELETE /api/history).
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=your-secure-admin-token-generated-with-openssl-rand

# --- CEIS (Cathedral Evolution Intelligence System) — all optional ---
# When set, /api/ceis/run requires "Authorization: Bearer <secret>".
# Vercel Cron sends CRON_SECRET automatically if configured in the project.
CEIS_CRON_SECRET=choose-a-long-random-secret
# Enables LLM principle extraction + DNA writing (falls back to heuristics without it).
OPENAI_API_KEY=sk-your-openai-api-key-here
# Enables the web-research collectors (Product Hunt, blogs, AI news, regulatory, talks).
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key-here
