# Firecrawl API key — get yours at https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key-here

# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Supabase — create a project at https://supabase.com
# Authentication uses Supabase Auth (email + password). After setting these:
#   1. Run supabase/schema.sql (fresh) OR supabase/migrations/0002_*.sql (existing).
#   2. In Supabase → Authentication → Providers, enable "Email".
#   3. (Optional) Authentication → URL Configuration: add your site URL for
#      email-confirmation redirects. Email confirmation on/off is your choice.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Public site URL (used for metadata + auth redirects). Optional in dev.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ---------------------------------------------------------------------------
# Durable rate limiting (OPTIONAL but recommended for production).
# Without these, rate limiting falls back to per-instance in-memory counters
# that reset on scale/restart (the app reports this honestly at /api/health).
# Create a free Redis at https://upstash.com and paste the REST URL + token.
# ---------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
