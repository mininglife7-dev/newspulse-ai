# EURO AI — AI Governance Platform
# Supabase configuration (create a project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_PROJECT_ID=your-project-ref

# Deployment & CI/CD configuration
GITHUB_OWNER=your-github-owner
GITHUB_REPO=your-github-repo

# Monitoring & Health Check
NEXT_PUBLIC_APP_URL=https://your-production-url.vercel.app

# Admin & Monitoring Authentication
# REQUIRED for production: Secure token for monitoring endpoints (/api/alerts, /api/incident, etc.)
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=your-secure-admin-token-generated-with-openssl-rand
