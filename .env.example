# Firecrawl API key — get yours at https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key-here

# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ── Optional ────────────────────────────────────────────────────────────────

# Canonical public site URL (no trailing slash). Used for metadataBase,
# sitemap.xml, and robots.txt. Defaults to https://newspulse-ai.vercel.app.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Protect the destructive endpoints (DELETE /api/history, DELETE
# /api/history/:id). When set, those calls require `Authorization: Bearer
# <token>` and the History UI prompts for the token before clearing. When
# unset, deletes are open (fine for a private demo, not a public URL).
# ADMIN_TOKEN=choose-a-long-random-secret

# Run without external APIs: /api/search returns sample articles and the UI
# labels them as demo data. Leave unset/false for real Firecrawl + OpenAI.
# DEMO_MODE=false
