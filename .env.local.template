# Copy this file to .env.local and fill in your rotated values.
# Never commit .env.local — it's already in .gitignore.

# ----- Firecrawl -----
# https://firecrawl.dev → Dashboard → API Keys
FIRECRAWL_API_KEY=

# ----- OpenAI -----
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ----- Supabase -----
# Project URL: Supabase dashboard → Settings → API → "Project URL"
# Should look like https://<20-char-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (new format, replaces anon JWT) — starts with sb_publishable_
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret key (new format, replaces service_role JWT) — starts with sb_secret_
# Server-only. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ----- Optional -----
# Used by app/sitemap.ts and app/robots.ts in production
NEXT_PUBLIC_SITE_URL=
