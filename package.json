{
  "name": "newspulse-ai",
  "version": "1.0.0",
  "private": true,
  "description": "EURO AI — AI Governance Platform for EU AI Act compliance",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "INCLUDE_INTEGRATION_TESTS=1 vitest run",
    "test:e2e": "playwright test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "check-env": "node --env-file=.env.local scripts/check-env.mjs",
    "test:smoke": "node scripts/smoke-test.mjs",
    "performance:baseline": "node scripts/performance-baseline.mjs",
    "performance:baseline:save": "node scripts/performance-baseline.mjs --save",
    "perf:measure": "node scripts/performance-measurement.mjs",
    "perf:measure:save": "node scripts/performance-measurement.mjs --save",
    "prepare": "husky install"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.66.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.7",
    "clsx": "^2.1.1",
    "lucide-react": "^0.453.0",
    "next": "16.2.10",
    "pdf-lib": "^1.17.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.4",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "husky": "^9.1.7",
    "lighthouse": "^13.4.0",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.10",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,css}": [
      "prettier --write"
    ]
  }
}
