{
  "name": "newspulse-ai",
  "version": "1.0.0",
  "private": true,
  "description": "EURO AI — AI Governance Platform for EU AI Act compliance",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "check-env": "node --env-file=.env.local scripts/check-env.mjs",
    "test:smoke": "node scripts/smoke-test.mjs",
    "prepare": "husky install"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.453.0",
    "next": "15.5.20",
    "react": "^18.3.1",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.20",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.4.47",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,css}": [
      "prettier --write"
    ]
  }
}
