{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "functions": {
    "app/api/search/route.ts": {
      "maxDuration": 60
    },
    "app/api/ceis/run/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/ceis/run",
      "schedule": "0 6 * * 1"
    }
  ]
}
