{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "functions": {
    "app/api/blocking-conditions/route.ts": {
      "maxDuration": 30
    },
    "app/api/production-health/route.ts": {
      "maxDuration": 30
    },
    "app/api/verify-deployment/route.ts": {
      "maxDuration": 30
    },
    "app/api/error-rate/route.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "GITHUB_TOKEN": "@github-token",
    "GITHUB_OWNER": "mininglife7-dev",
    "GITHUB_REPO": "newspulse-ai"
  },
  "crons": []
}
